# =============================================================================
# Chicago Pipeline — environment variables (example only)
# Copy to .env and fill in real values. NEVER commit .env.
# =============================================================================

ENV=local

# --- Postgres / PostGIS ---
POSTGRES_DB=chicago
POSTGRES_USER=chicago
POSTGRES_PASSWORD=change_me_local

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- MinIO ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me_local

# --- Airflow ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_local
AIRFLOW_FERNET_KEY=PLEASE_GENERATE_WITH_python_-c_"from_cryptography.fernet_import_Fernet;_print(Fernet.generate_key().decode())"_AND_PASTE_HERE
AIRFLOW_WEB_SECRET=change_me_local

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_local

# --- OpenLineage / Marquez ---
MARQUEZ_URL=http://marquez:3000
OPENLINEAGE_NAMESPACE=chicago_pipeline

# --- Logging ---
LOG_LEVEL=INFO
