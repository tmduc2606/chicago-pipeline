{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gold-schema.json",
  "title": "Gold Layer Schema — Chicago Crime",
  "description": "Schema contract for Gold Parquet output (fact_crime + 4 dimension tables). Data Engineer owns; Backend/QA consume.",
  "version": "1.0.0",
  "last_updated": "2026-06-04",
  "tables": {
    "fact_crime": {
      "description": "Central fact table — 1 row per crime incident",
      "partitioned_by": ["year"],
      "columns": {
        "crime_id": { "type": "long", "description": "Surrogate PK (hash-based, 64-bit deterministic)", "nullable": false },
        "time_id": { "type": "long", "description": "FK → dim_time.time_id", "nullable": false },
        "location_id": { "type": "long", "description": "FK → dim_location.location_id", "nullable": false },
        "offense_id": { "type": "long", "description": "FK → dim_offense.offense_id", "nullable": false },
        "case_id": { "type": "long", "description": "FK → dim_case.case_id", "nullable": false },
        "arrest": { "type": "boolean", "description": "Original arrest flag from Bronze", "nullable": false },
        "domestic": { "type": "boolean", "description": "Original domestic flag from Bronze", "nullable": false },
        "beat": { "type": "string", "description": "Police beat code", "nullable": true },
        "fbi_code": { "type": "string", "description": "FBI crime code", "nullable": true },
        "is_arrested": { "type": "boolean", "description": "Conforming boolean (M2 Extension)", "nullable": false },
        "is_domestic": { "type": "boolean", "description": "Conforming boolean (M2 Extension)", "nullable": false },
        "is_domestic_arrest": { "type": "boolean", "description": "Conforming boolean (M2 Extension)", "nullable": false },
        "is_unassigned_district": { "type": "boolean", "description": "Data quality flag: district IS NULL", "nullable": false },
        "is_unassigned_community": { "type": "boolean", "description": "Data quality flag: community_area IS NULL", "nullable": false },
        "is_unassigned_ward": { "type": "boolean", "description": "Data quality flag: ward IS NULL", "nullable": false },
        "hours_to_update": { "type": "integer", "description": "Hours between crime and record update, clipped [0, 8760]", "nullable": true },
        "date_dow": { "type": "integer", "description": "Day of week (0=Sun, 6=Sat)", "nullable": false },
        "year": { "type": "integer", "description": "Partition key: crime year", "nullable": false },
        "_gold_ingest_ts": { "type": "timestamp", "description": "Gold ingestion timestamp (audit)", "nullable": false }
      },
      "primary_key": ["crime_id"],
      "foreign_keys": {
        "time_id": "dim_time.time_id",
        "location_id": "dim_location.location_id",
        "offense_id": "dim_offense.offense_id",
        "case_id": "dim_case.case_id"
      }
    },
    "dim_time": {
      "description": "BCNF time dimension — 1 row per hour for full project range (2024-01-01 to 2026-12-31)",
      "columns": {
        "time_id": { "type": "long", "description": "Surrogate PK (hash-based)", "nullable": false },
        "date": { "type": "date", "description": "Calendar date", "nullable": false },
        "year": { "type": "integer", "description": "Year (2024-2026)", "nullable": false },
        "month": { "type": "integer", "description": "Month (1-12)", "nullable": false },
        "day": { "type": "integer", "description": "Day of month (1-31)", "nullable": false },
        "hour": { "type": "integer", "description": "Hour of day (0-23)", "nullable": false },
        "weekday": { "type": "string", "description": "Day name (Monday-Sunday)", "nullable": false },
        "is_weekend": { "type": "boolean", "description": "True if Saturday or Sunday", "nullable": false },
        "date_dow": { "type": "integer", "description": "Day of week (0=Sun, 6=Sat)", "nullable": false }
      },
      "primary_key": ["time_id"]
    },
    "dim_location": {
      "description": "Spatial dimension — 1 row per unique location",
      "columns": {
        "location_id": { "type": "long", "description": "Surrogate PK (hash-based)", "nullable": false },
        "block": { "type": "string", "description": "Block address (trimmed)", "nullable": true },
        "location_description": { "type": "string", "description": "Location type description", "nullable": true },
        "district": { "type": "integer", "description": "Police district (1-25)", "nullable": true },
        "ward": { "type": "integer", "description": "City ward", "nullable": true },
        "community_area": { "type": "integer", "description": "Community area number", "nullable": true },
        "latitude": { "type": "float", "description": "Latitude (Chicago bbox)", "nullable": true },
        "longitude": { "type": "float", "description": "Longitude (Chicago bbox)", "nullable": true },
        "is_downtown": { "type": "boolean", "description": "True if within downtown bbox (41.880-41.895, -87.635--87.618)", "nullable": false },
        "distance_to_downtown_km": { "type": "float", "description": "Haversine distance from downtown center (41.8819, -87.6278)", "nullable": false },
        "geom_wkt": { "type": "string", "description": "WKT POINT geometry (placeholder for PostGIS cast in M4)", "nullable": true }
      },
      "primary_key": ["location_id"]
    },
    "dim_offense": {
      "description": "Crime type dimension — 1 row per unique IUCR code",
      "columns": {
        "offense_id": { "type": "long", "description": "Surrogate PK (hash-based)", "nullable": false },
        "iucr": { "type": "string", "description": "Illinois Uniform Crime Reporting code", "nullable": false },
        "primary_type": { "type": "string", "description": "Primary crime type (ALL-CAPS)", "nullable": false },
        "description": { "type": "string", "description": "Crime description", "nullable": true },
        "fbi_code": { "type": "string", "description": "FBI crime code", "nullable": true }
      },
      "primary_key": ["offense_id"]
    },
    "dim_case": {
      "description": "Case tracking dimension — 1 row per unique case_number",
      "columns": {
        "case_id": { "type": "long", "description": "Surrogate PK (hash-based)", "nullable": false },
        "case_number": { "type": "string", "description": "Police case number (unique)", "nullable": false },
        "updated_on": { "type": "string", "description": "Record last updated timestamp (string, not cast)", "nullable": true }
      },
      "primary_key": ["case_id"]
    }
  },
  "design_decisions": {
    "surrogate_keys": "Hash-based (xxhash64 of natural key columns) for idempotent re-runs",
    "dim_time_range": "2024-01-01 to 2026-12-31, 1 row per hour, pre-generated",
    "is_downtown_bbox": "lat [41.880, 41.895], lon [-87.635, -87.618]",
    "downtown_center": "lat=41.8819, lon=-87.6278 (Chicago City Hall)",
    "geom_wkt": "Placeholder column as WKT string; PostGIS cast deferred to load_postgres.py (M4)",
    "partition_strategy": "fact_crime partitioned by year for large-scale growth",
    "sin_cos_encoding": "Deferred to dbt intermediate models (M4) per Medallion Architecture"
  }
}
