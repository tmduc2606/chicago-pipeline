{
  "$schema": "https://schemas.chicago-pipeline.local/design-tokens/v1.json",
  "version": "0.1.0",
  "owner": "frontend",
  "note": "This file is the source of truth for design tokens. The frontend agent owns it; breaking changes require a SemVer bump + ADR.",
  "color": {
    "brand": {
      "navy": "#0B1F3A",
      "cta": "#C8102E",
      "amber": "#FFB400",
      "slate": "#475569"
    },
    "semantic": {
      "background": {
        "default": "#0B1F3A",
        "subtle": "#102A4C",
        "muted": "#1B3A66"
      },
      "foreground": {
        "default": "#F8FAFC",
        "muted": "#94A3B8",
        "subtle": "#64748B"
      },
      "border": {
        "default": "#1E3A5F",
        "strong": "#3B82F6"
      },
      "success": "#10B981",
      "warning": "#F59E0B",
      "danger": "#EF4444",
      "info": "#3B82F6"
    },
    "chart": {
      "categorical": [
        "#C8102E",
        "#0B1F3A",
        "#FFB400",
        "#3B82F6",
        "#10B981",
        "#A855F7",
        "#F97316",
        "#06B6D4",
        "#84CC16",
        "#EAB308"
      ],
      "sequential": {
        "low": "#0B1F3A",
        "high": "#C8102E"
      },
      "diverging": {
        "low": "#3B82F6",
        "mid": "#F8FAFC",
        "high": "#C8102E"
      }
    }
  },
  "typography": {
    "font": {
      "ui": {
        "family": "Inter, system-ui, -apple-system, Segoe UI, sans-serif",
        "weights": [400, 500, 600, 700]
      },
      "mono": {
        "family": "JetBrains Mono, ui-monospace, SFMono-Regular, monospace",
        "weights": [400, 500, 700]
      }
    },
    "size": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem"
    },
    "lineHeight": {
      "tight": "1.2",
      "normal": "1.5",
      "loose": "1.75"
    }
  },
  "spacing": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "6": "1.5rem",
    "8": "2rem",
    "12": "3rem",
    "16": "4rem"
  },
  "radius": {
    "none": "0",
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem",
    "full": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(0,0,0,0.1)",
    "md": "0 4px 6px rgba(0,0,0,0.15)",
    "lg": "0 10px 15px rgba(0,0,0,0.2)"
  },
  "motion": {
    "duration": {
      "fast": "120ms",
      "normal": "200ms",
      "slow": "320ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.4, 0.0, 0.2, 1)",
      "decelerate": "cubic-bezier(0.0, 0.0, 0.2, 1)",
      "accelerate": "cubic-bezier(0.4, 0.0, 1, 1)"
    }
  }
}
