# =============================================================================
# API — environment variables
# All vars use the API_ prefix (pydantic-settings env_prefix).
# Docker-compose overrides these to point at service hostnames.
# =============================================================================

# --- Postgres ---
API_POSTGRES_HOST=localhost
API_POSTGRES_PORT=5432
API_POSTGRES_DB=chicago
API_POSTGRES_USER=chicago
API_POSTGRES_PASSWORD=change_me_local

# --- Redis ---
API_REDIS_HOST=localhost
API_REDIS_PORT=6379
API_REDIS_PASSWORD=changeme

# --- Airflow ---
API_AIRFLOW_BASE_URL=http://localhost:8080
API_AIRFLOW_USER=admin
API_AIRFLOW_PASSWORD=admin

# --- App ---
API_ENV=local
API_CACHE_TTL=300
